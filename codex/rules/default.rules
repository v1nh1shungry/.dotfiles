prefix_rule(
    pattern=[["cat", "echo", "file", "grep", "head", "ls", "pwd", "rg", "tail", "wc"]],
    decision="allow",
)

prefix_rule(
    pattern=["git", ["blame", "diff", "grep", "log", "ls-files", "rev-parse", "show", "status"]],
    decision="allow",
)

prefix_rule(
    pattern=["git", ["add", "clean", "commit", "push", "rebase", "reset", "restore", "rm"]],
    decision="forbidden",
)

prefix_rule(
    pattern=["rm"],
    decision="forbidden",
)

