{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "variant": "none"
    },
    "general": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "title": {
      "model": "openai/gpt-5.4-mini",
      "variant": "none"
    }
  },
  "autoupdate": false,
  "default_agent": "plan",
  "enabled_providers": [
    "openai"
  ],
  "formatter": false,
  "lsp": true,
  "permission": {
    "bash": {
      "*": "ask",
      "file *": "allow",
      "git blame *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "zgrep *": "allow"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "share": "disabled",
}
