{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "explore": {
      "hidden": true,
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "hidden": true,
      "model": "opencode-go/glm-5.1"
    },
    "plan": {
      "disable": true
    },
    "scout": {
      "disable": true
    },
    "title": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "autoupdate": "notify",
  "enabled_providers": [
    "openai",
    "opencode-go"
  ],
  "formatter": false,
  "lsp": true,
  "permission": {
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "date *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "git add *": "deny",
      "git blame *": "allow",
      "git clean *": "deny",
      "git commit *": "deny",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git push *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git restore *": "deny",
      "git rev-parse *": "allow",
      "git rm *": "deny",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "rm *": "deny",
      "tail *": "allow",
      "wc *": "allow"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "share": "disabled"
}
