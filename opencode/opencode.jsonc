{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "prune": false
  },
  "default_agent": "plan",
  "enabled_providers": [
    "openai",
  ],
  "formatter": false,
  "model": "openai/gpt-5.5",
  "permission": {
    "bash": {
      "*": "ask",
      "file *": "allow",
      "git blame *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "zgrep *": "allow",
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "share": "disabled",
  "small_model": "openai/gpt-5.4-mini"
}
