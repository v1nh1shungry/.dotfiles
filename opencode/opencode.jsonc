{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "prune": false
  },
  "default_agent": "plan",
  "enabled_providers": [
    "openai",
  ],
  "formatter": false,
  "model": "openai/gpt-5.4",
  "permission": {
    "bash": {
      "*": "ask",
      "file *": "allow",
      "head *": "allow",
      "rtk git blame *": "allow",
      "rtk git diff *": "allow",
      "rtk git grep *": "allow",
      "rtk git log *": "allow",
      "rtk git show *": "allow",
      "rtk git status *": "allow",
      "rtk grep *": "allow",
      "rtk ls *": "allow",
      "rtk rg *": "allow",
      "zgrep *": "allow",
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "share": "disabled",
  "small_model": "openai/gpt-5.4-mini"
}
