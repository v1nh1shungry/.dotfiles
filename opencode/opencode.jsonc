{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "prune": false
  },
  "default_agent": "plan",
  "enabled_providers": [
    "openai",
    "opencode"
  ],
  "formatter": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "model": "openai/gpt-5.4",
  "permission": {
    "bash": {
      "*": "ask",
      "rtk git diff *": "allow",
      "rtk git log *": "allow",
      "rtk git show *": "allow",
      "rtk git status *": "allow",
      "rtk grep *": "allow",
      "rtk ls *": "allow",
      "rtk rg *": "allow",
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{env:OPENCODE_OPENAI_API_KEY}",
        "baseURL": "{env:OPENCODE_OPENAI_BASE_URL}",
        "setCacheKey": true
      }
    }
  },
  "share": "disabled",
  "small_model": "opencode/gpt-5-nano"
}
