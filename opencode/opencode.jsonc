{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "explore": {
      "hidden": true,
      "model": "deepseek/deepseek-v4-flash"
    },
    "general": {
      "hidden": true,
      "model": "deepseek/deepseek-v4-pro"
    },
    "plan": {
      "disable": true
    },
    "scout": {
      "hidden": true,
      "model": "deepseek/deepseek-v4-flash"
    },
    "title": {
      "model": "openai/gpt-5.4-mini",
      "variant": "none"
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "prune": false
  },
  "enabled_providers": [
    "deepseek",
    "openai"
  ],
  "formatter": false,
  "lsp": true,
  "permission": {
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "file *": "allow",
      "git blame *": "allow",
      "git clean *": "deny",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git push *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git restore *": "deny",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "rm *": "deny",
      "tail *": "allow",
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "share": "disabled"
}
