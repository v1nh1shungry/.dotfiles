{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "git add *": "deny",
      "git blame *": "allow",
      "git clean *": "deny",
      "git commit *": "deny",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git push *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git restore *": "deny",
      "git rev-parse *": "allow",
      "git rm *": "deny",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "rm *": "deny",
      "tail *": "allow",
      "wc *": "allow"
    },
    "external_directory": "ask",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  }
}
